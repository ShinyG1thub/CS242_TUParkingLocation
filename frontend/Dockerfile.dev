# ---- Frontend: Development ----
# ใช้สำหรับ Development เท่านั้น (Vite Dev Server)
# สำหรับ Production ให้ดู docker-compose.prod.yml แทน

FROM node:20-alpine
WORKDIR /frontend

COPY package.json package-lock.json* ./
RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host"]
